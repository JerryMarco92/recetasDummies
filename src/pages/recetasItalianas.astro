---
import Layout from "../layouts/Layout.astro";
import RecipeList from "../components/RecipeList.astro";
import { getRecipes } from "../data/recipes";

const recetas = await getRecipes();

const recetasItalianas = recetas.filter(
  (receta) => receta.tipo === "Italian"
);
---

<Layout title="Recetas italianas">

  <RecipeList recetas={recetasItalianas} mostrarTipo={false} />

</Layout>