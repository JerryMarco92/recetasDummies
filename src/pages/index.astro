---
import Layout from "../layouts/Layout.astro";
import RecipeList from "../components/RecipeList.astro";
import global from "../styles/global.css";

import { getRecipes } from "../data/recipes";

const recetas = await getRecipes();

const destacada = recetas[6];

import imagenPortada from "../assets/principal.png";
---
<Layout title="Inicio">
	<main>
		<p>
			Estas ante la mejor seleccion de recetas del mundo. Descubre platos
			fáciles, rápidos y explicados paso a paso para que cualquiera pueda
			cocinar sin complicaciones. Desde entrantes hasta postres, aquí
			encontrarás ideas deliciosas para sorprender a familiares y amigos.
		</p>
		<section class="centro">
			<div id="imgPrincipal">
				<img src={imagenPortada.src} alt="foto de mesa elegante con asado y vino" />
			</div>
			<aside>
				<h2>Receta destacada de la semana </h2>
				<div class="receta-destacada">
					<div class="card-img">
						<img src={destacada.imagen} alt={destacada.nombre} />

						<div class="overlay">
							<h3>{destacada.nombre}</h3>
						</div>
					</div>
					<div id= "especificaciones">
						<p>{destacada.tiempo} min</p>
						<p>{destacada.tipo}</p>
						<p>{destacada.dificultad}</p>
						<p>Ingredients: {destacada.ingredientes}</p>
						<a href={`/receta/${destacada.id}`}>Ver más...</a>
					</div>
				</div>





			</aside>
		</section>
	</main>
</Layout>

<style>


	main {
		max-width: 1400px;
		margin: 0 auto;
		padding: 1rem 2rem;
	}

	/* Texto superior */

	main > p {
		width: min(800px, 80%);
		text-align: end;
		font-size: 1.1rem;
		line-height: 1.6;
	}

	/* Contenedor principal */

	.centro {
		display: flex;
		gap: 2rem;
		align-items: flex-start;
	}

	/* Imagen principal */

	.centro > div {
		flex: 1;
	}

	.centro > div img {
		width: 100%;
		max-height: 70vh;
		object-fit: cover;
		display: block;
		border-radius: 16px;
	}


	/* Aside */

	aside {
		width: 340px;
		flex-shrink: 0;
	}

	/* Título */

	aside h2 {
		text-align: center;
		margin-bottom: 1rem;
		color: #175237;
	}

	/* Card */

	.receta-destacada {
		background: #f4a361;
		border-radius: 16px;
		overflow: hidden;
		border: 2px solid #175238d2;
		display: flex;
		flex-direction: column;
	}

	/* Imagen de la receta */

	.card-img {
		position: relative;
		height: 220px;
	}

	.card-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Nombre sobre imagen */

	.overlay {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;

		padding: 1.5rem;

		background: linear-gradient(
			to top,
			#f4a361,
			transparent
		);
	}

	.overlay h3 {
		margin: 0;
		color: #175237;
		font-size: 20px;
	}

	/* Información */

	#especificaciones {
		padding: 1.25rem;
		color: #175237;
		display: flex;
		flex-direction: column;
		gap: .75rem;
	}

	#especificaciones p {
		margin: 0;
		line-height: 1.4;
	}

	#especificaciones a {
		margin-top: auto;
		font-weight: bold;
	}

	/* Responsive */




	@media (max-width: 1250px) {

	

		main {
			padding: 1rem;
		}

		main > p {
			width: 100%;
		}

		.centro{
			flex-direction: column;
		
		}

		#imgPrincipal{
			margin: auto;
		}

		

		aside {
			margin: auto;
			width: 80%;
		}

		.card-img {
			height: 200px;
		}
	}



</style>