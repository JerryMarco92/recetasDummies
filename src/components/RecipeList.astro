---
import "../styles/recipes.css";

const {
  recetas,
  mostrarTipo = true
} = Astro.props;

import { Image } from "astro:assets";
---

<div class="cards">
    {
        recetas.map((reci) => (
            
            
                <div class="card">
                    <div class="img">
                            <Image src={reci.imagen} alt={reci.nombre} width={400} height={250} />
                    </div>

                        <div class="fondo">
                        <span>{reci.dificultad}</span>
                        <h3>{reci.nombre}</h3>
                        <p>{reci.tiempo} min</p>
                        {mostrarTipo ? <p>{reci.tipo}</p> : null}
                        
                        <a href={`/receta/${reci.id}`} class="ver-mas">
                        Ver receta
                        </a>
                    </div>
                     
    
                </div>
            
        ))
    }
</div>


<style>

a {
  list-style:none;
  text-decoration: none;
  
}

</style>